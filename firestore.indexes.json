{
  "indexes": [
    // ─────────────────────────────────────────────
    // Business & Services (common queries)
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "services",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "businessId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "isActive",
          "order": "ASCENDING"
        }
      ]
    },
    {
      "collectionGroup": "businessHours",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "businessId",
          "order": "ASCENDING"
        }
      ]
    },

    // ─────────────────────────────────────────────
    // Bookings (very important for calendar + filtering)
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "businessId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "date",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "status",
          "order": "ASCENDING"
        }
      ]
    },
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "businessId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "paymentStatus",
          "order": "ASCENDING"
        }
      ]
    },
    {
      "collectionGroup": "bookings",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "businessId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "startTime",
          "order": "ASCENDING"
        }
      ]
    },

    // ─────────────────────────────────────────────
    // Employees & Attendance (clock-in/out, payroll calc)
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "attendance",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "businessId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "date",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "employeeId",
          "order": "ASCENDING"
        }
      ]
    },
    {
      "collectionGroup": "employees",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "businessId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "activeStatus",
          "order": "ASCENDING"
        }
      ]
    },

    // ─────────────────────────────────────────────
    // Payroll & Invoices
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "payroll",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "businessId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "month",
          "order": "ASCENDING"
        }
      ]
    },
    {
      "collectionGroup": "invoices",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "businessId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "date",
          "order": "DESCENDING"
        }
      ]
    },

    // ─────────────────────────────────────────────
    // AI Chat History (per user, ordered by time)
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "messages",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        {
          "fieldPath": "userId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "timestamp",
          "order": "ASCENDING"
        }
      ]
    },

    // ─────────────────────────────────────────────
    // Notifications (by user or business)
    // ─────────────────────────────────────────────
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        {
          "fieldPath": "userId",
          "order": "ASCENDING"
        },
        {
          "fieldPath": "createdAt",
          "order": "DESCENDING"
        }
      ]
    }
  ]
}